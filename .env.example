# Shared application metadata
APP_NAME=Real Capita ERP

# Local service ports
WEB_PORT=3000
API_PORT=3333
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Frontend public URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3333

# Backend routing and docs
API_GLOBAL_PREFIX=api
API_VERSION=1
ENABLE_SWAGGER=true
SWAGGER_PATH=api/docs
CORS_ORIGIN=http://localhost:3000

# Database
POSTGRES_DB=real_capita_erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql://postgres:change-me-postgres-password@localhost:5432/real_capita_erp?schema=public

# Auth placeholders
JWT_ACCESS_TOKEN_SECRET=change-me-access-token-secret
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_SECRET=change-me-refresh-token-secret
JWT_REFRESH_TOKEN_TTL=7d

# Object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=real-capita-erp-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio-access-secret
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-root-password
