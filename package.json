{
  "name": "real-capita-erp",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.32.1"
  },
  "scripts": {
    "dev": "node ./node_modules/nx/bin/nx.js run-many -t dev --projects=web,api --parallel=2",
    "dev:web": "node ./node_modules/nx/bin/nx.js dev web",
    "dev:api": "node ./node_modules/nx/bin/nx.js dev api",
    "verify": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm build && corepack pnpm test",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:infra": "docker compose up -d postgres minio",
    "docker:migrate": "docker compose --profile ops run --rm api-migrate",
    "docker:bootstrap": "node scripts/docker-bootstrap.mjs",
    "docker:smoke": "node scripts/wait-for-stack.mjs",
    "build": "cross-env NODE_ENV=production node ./node_modules/nx/bin/nx.js run-many -t build --all",
    "build:web": "cross-env NODE_ENV=production node ./node_modules/nx/bin/nx.js build web",
    "build:api": "node ./node_modules/nx/bin/nx.js build api",
    "lint": "node ./node_modules/nx/bin/nx.js run-many -t lint --all",
    "typecheck": "node ./node_modules/nx/bin/nx.js run-many -t typecheck --all",
    "test": "node ./node_modules/nx/bin/nx.js run-many -t test --all",
    "test:api": "node ./node_modules/nx/bin/nx.js run api:test",
    "test:e2e": "node ./node_modules/nx/bin/nx.js run e2e:test",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "prisma:format": "prisma format --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "auth:bootstrap": "node ./node_modules/nx/bin/nx.js run api:bootstrap-admin"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@hookform/resolvers": "^5.2.2",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.7.0",
    "@tanstack/react-query": "^5.79.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^16.1.6",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/nest": "22.5.4",
    "@nx/next": "22.5.4",
    "@nx/node": "22.5.4",
    "@nx/playwright": "22.5.4",
    "@nx/react": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/webpack": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@playwright/test": "^1.55.1",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.18",
    "@swc/helpers": "~0.5.17",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "nx": "22.5.4",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "webpack-cli": "^5.1.4"
  }
}
