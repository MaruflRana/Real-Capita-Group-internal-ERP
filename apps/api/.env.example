APP_NAME=Real Capita ERP API
NODE_ENV=development
API_PORT=3333
API_GLOBAL_PREFIX=api
API_VERSION=1
ENABLE_SWAGGER=true
SWAGGER_PATH=api/docs
WEB_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3333
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://postgres:change-me-postgres-password@localhost:5432/real_capita_erp?schema=public

JWT_ACCESS_TOKEN_SECRET=change-me-local-access-token-secret-1234567890
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_SECRET=change-me-local-refresh-token-secret-123456789
JWT_REFRESH_TOKEN_TTL=7d

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=real-capita-erp-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio-root-password
S3_FORCE_PATH_STYLE=true
