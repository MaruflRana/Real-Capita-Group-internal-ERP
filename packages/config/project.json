{
  "name": "config",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/config/src",
  "projectType": "library",
  "tags": ["type:config", "scope:shared", "platform:neutral"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/config"],
      "options": {
        "command": "tsc --pretty false --project packages/config/tsconfig.build.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --pretty false --noEmit --project packages/config/tsconfig.json"
      }
    }
  }
}
